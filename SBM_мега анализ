def generate_radar_chart(param, radar_data, safe_param, safe_time, start_time_str, title_prefix="RCA"):
    if not radar_data: return
    
    labels = list(radar_data.keys())
    values = [abs(v) for v in radar_data.values()] 
    actual_r = list(radar_data.values())
    
    labels = [param] + labels
    values = [1.0] + values
    actual_r = [1.0] + actual_r
    
    while len(labels) < 3:
        labels.append("")
        values.append(0)
        actual_r.append(0)
        
    N = len(labels)
    angles = [n / float(N) * 2 * np.pi for n in range(N)]
    angles += angles[:1]
    values += values[:1]
    
    fig, ax = plt.subplots(figsize=(6, 6), subplot_kw=dict(polar=True))
    ax.set_theta_offset(np.pi / 2)
    ax.set_theta_direction(-1)
    
    plt.xticks(angles[:-1], labels, size=9, fontweight='bold')
    ax.set_rlabel_position(0)
    plt.yticks([0.25, 0.5, 0.75, 1.0], ["0.25", "0.5", "0.75", "1.0"], color="grey", size=7)
    plt.ylim(0, 1.05)
    
    color = 'red' if 'Отклонения' in title_prefix else 'blue'
    ax.plot(angles, values, linewidth=2, linestyle='solid', color=color)
    ax.fill(angles, values, color, alpha=0.15)
    
    for i, (angle, v, r) in enumerate(zip(angles[:-1], values[:-1], actual_r[:-1])):
        if labels[i]:
            ax.text(angle, v + 0.1, f"r={r:.2f}", ha='center', va='center', size=9, color='darkred', 
                    bbox=dict(facecolor='white', alpha=0.7, edgecolor='none', pad=1))
            
    plt.title(f"{title_prefix}: {param}\nВремя: {start_time_str}", size=12, y=1.1, fontweight='bold')
    
    prefix_file = "RCA_Dev" if 'Отклонения' in title_prefix else "RCA_Act"
    plot_path = os.path.join(RCA_FOLDER, f'{prefix_file}_{safe_param}_{safe_time}.png')
    plt.savefig(plot_path, dpi=DPI, bbox_inches='tight')
    plt.close(fig)

def visualize_results(data, param, worst_rca_text="", peak_time_dev=None, peak_val_dev=None, peak_time_act=None, peak_val_act=None):
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 10), gridspec_kw={'height_ratios': [3, 1]})
    plot_data = data.dropna(subset=['Predicted'])
    
    ax1.plot(data.index, data['Actual'], label='Фактические значения', color='blue', linewidth=1.5)
    ax1.plot(plot_data.index, plot_data['Predicted'], '.', label='Прогноз SBM', color='orange', markersize=3)
    ax1.set_title(f'Параметр: {param}', fontsize=12, fontweight='bold')
    ax1.legend(loc='center left', bbox_to_anchor=(1.01, 0.5), fontsize=10)
    ax1.grid(alpha=0.3)
    ax1.xaxis.set_major_formatter(DateFormatter('%Y-%m-%d\n%H:%M:%S'))

    ax2.plot(plot_data.index, plot_data['Deviation'], color='red', linewidth=1.0, label='Отклонение')
    ax2.plot(plot_data.index, plot_data['Threshold'], 'k--', alpha=0.6, label=f'+{SIGMA_MULTIPLIER}σ (Уставка)')
    ax2.plot(plot_data.index, -plot_data['Threshold'], 'k--', alpha=0.6, label=f'-{SIGMA_MULTIPLIER}σ (Уставка)')
    ax2.axhline(0, color='black', linestyle='-', linewidth=0.8)
    ax2.fill_between(plot_data.index, plot_data['Threshold'], -plot_data['Threshold'], color='gray', alpha=0.1)
    
    if worst_rca_text:
        props = dict(boxstyle='round,pad=0.5', facecolor='lightyellow', alpha=0.9, edgecolor='red')
        text_str = "🚨 ТОП связанных параметров (RCA):\n\n" + worst_rca_text
        ax2.text(1.01, 1.0, text_str, transform=ax2.transAxes, fontsize=10,
                verticalalignment='top', horizontalalignment='left', bbox=props, color='darkred')
        
        # Точка 1: Пик Отклонений
        if peak_time_dev is not None and peak_val_dev is not None:
            ax2.plot(peak_time_dev, peak_val_dev, marker='o', color='darkred', markersize=8, zorder=10)
            ax2.annotate('Пик Отклонений RCA', xy=(peak_time_dev, peak_val_dev), xytext=(15, 15),
                         textcoords='offset points', arrowprops=dict(arrowstyle='->', color='darkred'),
                         color='darkred', fontsize=10, fontweight='bold', zorder=10)
                         
        # Точка 2: Пик Фактов (размещаем на ax2 по величине отклонения в тот момент времени)
        if peak_time_act is not None and peak_val_act is not None:
            # Сдвинем текст аннотации, чтобы стрелки не сливались, если пики близко
            ax2.plot(peak_time_act, peak_val_act, marker='o', color='darkblue', markersize=8, zorder=10)
            ax2.annotate('Пик Фактов RCA', xy=(peak_time_act, peak_val_act), xytext=(15, -25),
                         textcoords='offset points', arrowprops=dict(arrowstyle='->', color='darkblue'),
                         color='darkblue', fontsize=10, fontweight='bold', zorder=10)

    ax2.legend(loc='lower left', bbox_to_anchor=(1.01, 0.0), fontsize=10)
    ax2.grid(alpha=0.3)
    ax2.xaxis.set_major_formatter(DateFormatter('%Y-%m-%d\n%H:%M:%S'))

    safe_param = str(param).translate(str.maketrans('<>:"/\\|?*', '_________'))
    plot_path = os.path.join(PLOT_FOLDER, f'{safe_param}.png')
    plt.savefig(plot_path, dpi=DPI, bbox_inches='tight')
    plt.close()

def save_output(results, summary, mode_summary, incident_log):
    with pd.ExcelWriter(OUTPUT_FILE, engine='openpyxl') as writer:
        if incident_log:
            df_incidents = pd.DataFrame(incident_log)
            df_incidents = df_incidents.sort_values(by='Время начала', ascending=False)
            df_incidents.to_excel(writer, sheet_name='Журнал инцидентов', index=False)
        else:
            pd.DataFrame({"Сообщение": ["Инцидентов не зафиксировано"]}).to_excel(writer, sheet_name='Журнал инцидентов', index=False)

        cols = ['Параметр', 'MAPE(%)', 'Макс. отклонение', 'MBE (Смещение)', 'RMSE', 'R2 (Детерминация)']
        pd.DataFrame(summary, columns=cols).to_excel(writer, sheet_name='Сводка', index=False)
        
        cols_mode = ['Режим', 'Параметр', 'Ср. абсолютная ошибка (MAE)']
        pd.DataFrame(mode_summary, columns=cols_mode).to_excel(writer, sheet_name='Диагностика по режимам', index=False)
        
        for param, df in results.items():
            safe_sheet_name = str(param).translate(str.maketrans('[]:*?/\\', '_______'))[:31]
            df.to_excel(writer, sheet_name=safe_sheet_name, index_label='Дата', float_format="%.4f")

