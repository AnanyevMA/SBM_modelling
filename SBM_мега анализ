class BigDataProcessor:
    def __init__(self, file_path):
        self.file_path = file_path
        self.encoding = self._detect_encoding()

    def _detect_encoding(self):
        encodings_to_try = ['utf-8', 'cp1251', 'latin-1', 'ansi']
        for enc in encodings_to_try:
            try:
                with open(self.file_path, 'r', encoding=enc) as f:
                    f.read(8192)
                logging.info(f"[{os.path.basename(self.file_path)}] Кодировка: {enc}")
                return enc
            except UnicodeDecodeError:
                continue
        return 'utf-8'

    def _count_rows(self):
        with open(self.file_path, 'r', encoding=self.encoding) as f:
            return sum(1 for _ in f) - 1 

    def stream_data(self):
        chunks = []
        with tqdm(total=self._count_rows(), desc=f"Чтение {os.path.basename(self.file_path)}", unit=' строк', file=sys.stdout) as pbar:
            for chunk in pd.read_csv(self.file_path, sep=SEPARATOR, chunksize=CHUNK_SIZE, encoding=self.encoding):
                date_col = chunk.columns[0]
                date_series = chunk[date_col].astype(str)
                parsed_dates = pd.Series(pd.NaT, index=chunk.index)
                
                if DATE_FORMATS:
                    for fmt in DATE_FORMATS:
                        mask = parsed_dates.isna()
                        if not mask.any(): break
                        parsed_dates[mask] = pd.to_datetime(date_series[mask], format=fmt, errors='coerce')
                
                mask = parsed_dates.isna()
                if mask.any():
                    parsed_dates[mask] = pd.to_datetime(date_series[mask], dayfirst=True, errors='coerce')
                
                chunk[date_col] = parsed_dates
                chunk = chunk.dropna(subset=[date_col])
                chunk = chunk.set_index(date_col)
                chunks.append(chunk)
                pbar.update(len(chunk))
                
        return pd.concat(chunks)

def preprocess_data(df):
    string_columns = df.select_dtypes(include=['object']).columns
    for col in string_columns:
        df[col] = df[col].astype(str).str.replace(',', '.', regex=False)
        
    df = df.apply(pd.to_numeric, errors='coerce')
    df = df.dropna(axis=1, how='all')
    df = df.fillna(df.mean())
    df = df.replace([np.inf, -np.inf], np.nan).dropna(axis=1)
    return df.astype(np.float32)

class SBMEngine:
    def __init__(self, train_data, lambda_reg=LAMBDA_REG):
        self.D = train_data.astype(np.float32)
        self.M, self.L = self.D.shape
        self.lambda_reg = lambda_reg
        self.K_inv = self._compute_similarity_matrix()

    def _compute_similarity_matrix(self):
        K = similarity_kernel(self.D)
        K += self.lambda_reg * np.eye(self.M, dtype=np.float32)
        return pinvh(K).astype(np.float32)

    def predict(self, X):
        return predict_kernel(self.D, self.K_inv, X.astype(np.float32))

@njit(parallel=True, fastmath=True)
def similarity_kernel(D):
    M, L = D.shape
    K = np.zeros((M, M), dtype=np.float32)
    for i in prange(M):
        for j in prange(i + 1):
            if i == j:
                K[i, j] = L
            else:
                diff = np.abs(D[i] - D[j])
                K[i, j] = np.sum(1.0 / (1.0 + diff))
                K[j, i] = K[i, j]
    return K

@njit(parallel=True, fastmath=True)
def predict_kernel(D, K_inv, X):
    predictions = np.zeros((X.shape[0], D.shape[1]), dtype=np.float32)
    for i in prange(X.shape[0]):
        x = X[i]
        diff = np.abs(D - x)
        similarities = 1.0 / (1.0 + diff)
        k = np.sum(similarities, axis=1).astype(np.float32)
        w_hat = K_inv @ k
        w = w_hat / np.sum(w_hat)
        w = w.astype(np.float32)
        D_transposed = D.T.astype(np.float32)
        predictions[i] = D_transposed @ w
    return predictions

